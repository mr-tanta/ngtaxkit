{
  "name": "ngtaxkit",
  "version": "0.0.5",
  "description": "Nigerian tax compliance SDK — VAT, PAYE, WHT, Pension, Payroll, Invoicing. NTA 2025 compliant.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "author": "Abraham Tanta <sir.tanta@gmail.com> (https://github.com/mr-tanta)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mr-tanta/ngtaxkit.git",
    "directory": "packages/typescript"
  },
  "bugs": {
    "url": "https://github.com/mr-tanta/ngtaxkit/issues"
  },
  "homepage": "https://ngtaxkit.dev",
  "keywords": [
    "nigeria",
    "tax",
    "vat",
    "paye",
    "wht",
    "payroll",
    "pension",
    "invoice",
    "compliance",
    "nta-2025",
    "fintech"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "lint": "eslint src/",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "optionalDependencies": {
    "pdfkit": "^0.18.0"
  },
  "devDependencies": {
    "@ngtaxkit/core": "*",
    "@types/pdfkit": "^0.17.5",
    "fast-check": "^4.6.0",
    "tsup": "^8.0.0",
    "typescript": "^5.8.0",
    "vitest": "^3.0.0"
  }
}
